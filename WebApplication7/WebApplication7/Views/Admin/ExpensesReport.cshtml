
@{
    ViewBag.Title = "ExpensesReport";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="right_col" role="main">
    <div class="col-md-12 col-sm-12 col-xs-12">
        <div class="x_panel">
            <div class="x_title">
                <h2 style="font-size:16px;">➕Expenses List <small></small></h2>
                <div class="clearfix"></div>
            </div>
            <div class="x_content">

                <div class="container">


                    <table id="tblAdmission" class="table table-bordered table-striped">

                        <thead style="background:#2a5966;color:white;">
                            <tr>
                                <th>Sr. No.</th>
                                <th>Expense Head</th>
                                <th>Person</th>
                                <th>Amount</th>
                                <th>Pay Mode</th>
                                <th>Remark</th>
                                <th>Bill No/Image</th>
                                <th>Date</th>
                                <th>Action</th>

                            </tr>
                        </thead>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
<script>

    var table; // GLOBAL variable

    $(document).ready(function () {

        table = $('#tblAdmission').DataTable({

            paging: true,
            searching: true,
            ordering: true,
            info: true,

            ajax: {
                url: '/Admin/GetExpenseList', // Controller Action
                type: 'GET',
                datatype: 'json',
                dataSrc: 'data'   // IMPORTANT if returning List<>
            },

            columns: [

                {
                    data: null,
                    render: function (data, type, row, meta) {
                        return meta.row + 1;
                    }
                },

                { data: 'ExpensesHead' },
                { data: 'PersonName' },
                { data: 'Amount' },
                { data: 'PayMode' },
                { data: 'Remark' },

                {
                    data: 'BillImg',
                    render: function (data) {
                        if (data)
                            return '<a href="/Uploads/' + data + '" target="_blank">View</a>';
                        else
                            return '';
                    }
                },

                {
                    data: 'BillDate',
                    
                },

                {
                    data: 'ExpensesID',
                    render: function (data) {

                        return '<button class="btn btn-danger btn-sm" onclick="DeleteExpense(' + data + ')">Delete</button>';
                    }
                }
            ]
        });

    });


    function DeleteExpense(id) {

        if (!confirm("Are you sure you want to delete this record?"))
            return;

        $.ajax({
            url: '/Admin/DeleteExpenses',
            type: 'POST',
            data: { id: id },

            success: function (response) {

                if (response.result) {

                    alert(response.message);

                    table.ajax.reload(); // refresh datatable

                } else {

                    alert(response.message);
                }
            },

            error: function () {

                alert("Delete failed");
            }
        });
    }

    function Success(response) {

        if (response.Status) {

            alert(response.Message);

            $('#formsubmit')[0].reset();

            table.ajax.reload(); // refresh table
        }
    }


    function Fail() {

        alert("Error occurred");
    }

</script>
