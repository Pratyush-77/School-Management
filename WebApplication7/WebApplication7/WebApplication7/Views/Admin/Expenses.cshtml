@model WebApplication7.Models.ExpensesModel
@{
    ViewBag.Title = "Expenses";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="right_col" role="main">
    <div class="col-md-12 col-sm-12 col-xs-12">
        <div class="x_panel">
            <div class="x_title">
                <h2 style="font-size:16px;">➕Daily Expenses  <small></small></h2>
                <div class="clearfix"></div>
            </div>
            <div class="x_content">


                @using (Ajax.BeginForm("Expenses", "Admin", new AjaxOptions() { OnSuccess = "Success", OnFailure = "Fail" }, new { @id = "formsubmit", @class = "form-horizontal", enctype = "multipart/form-data" }))
                {
                    <div>
                        @Html.HiddenFor(m => m.ExpensesID)
                    </div>

                    <div class="row">

                        <div class="col-md-3 col-sm-3 col-xs-12">
                            <label class="control-label">Select Expenses Head<span class="star">*</span></label>
                            @Html.DropDownListFor(m => m.ExpenseHeadID, Model.ExpenseHeadList, "-- Select Expense Head --", new { @class = "form-control", id = "ExpenseHeadID" })

                        </div>

                        <div class="col-md-3 col-sm-3 col-xs-12">
                            <label class="control-label">Bill Date <span class="star">*</span></label>
                            @Html.TextBoxFor(m => m.BillDate, "{0:YYYY-MM-dd}", new { @class = "form-control", @required = "required", type = "date" })

                        </div>
                        <div class="col-md-3 col-sm-3 col-xs-12">
                            <label class="control-label">Bill No<span class="star">*</span></label>
                            @Html.TextBoxFor(m => m.BillNo, new { @class = "form-control", @required = "required" })

                        </div>

                        <div class="col-md-3 col-sm-3 col-xs-12">
                            <label class="control-label">Bill Image<span class="star">*</span></label>
                            @Html.TextBoxFor(m => m.BillImage, new { @class = "form-control", @required = "required", @type = "file" })

                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-3 col-sm-2 col-xs-12">
                            <label class="control-label">Amount<span class="star">*</span></label>
                            @Html.TextBoxFor(m => m.Amount, new { @class = "form-control", @required = "required" })
                        </div>

                        <div class="col-md-3 col-sm-3 col-xs-12">
                            <label class="control-label">Person Name<span class="star">*</span></label>
                            @Html.TextBoxFor(m => m.PersonName, new { @class = "form-control", @required = "required" })

                        </div>

                        <div class="col-md-3 col-sm-3 col-xs-12">
                            <label class="control-label">Pay Mode<span class="star">*</span></label>
                            @Html.DropDownListFor(x => x.PayMode, new[]{

                            new SelectListItem() { Text = "Cash"},
                            new SelectListItem() { Text = "Online"},
                            }, "Select Payment mode", new { @class = "form-control" })


                        </div>

                        <div class="col-md-3 col-sm-3 col-xs-12">
                            <label class="control-label">Remark<span class="star">*</span></label>
                            @Html.TextBoxFor(m => m.Remark, new { @class = "form-control", @required = "required" })

                        </div>

                    </div>
                    <br />
                    <div class="row">
                        <div class="col-md-3 col-sm-3 col-xs-12">
                            <button type="submit" class="btn btn-success">
                                Save
                            </button>
                        </div>
                    </div>


                }

            </div>
            <div class="container mt-4">

                <table id="expenseHeadTable" class="table table-bordered table-striped">

                    <thead>
                        <tr>
                            <th>Sr. No.</th>
                            <th>Expense Head</th>
                            <th>Person</th>
                            <th>Amount</th>
                            <th>Pay Mode</th>
                            <th>Remark</th>
                            <th>Bill No/Image</th>
                            <th>Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>

<script>

    var table; // GLOBAL variable

    $(document).ready(function () {

        table = $('#expenseHeadTable').DataTable({

            paging: true,
            searching: true,
            ordering: true,
            info: true,

            ajax: {
                url: '/Admin/GetExpenseList', // Controller Action
                type: 'GET',
                datatype: 'json',
                dataSrc: 'data'   // IMPORTANT if returning List<>
            },

            columns: [

                {
                    data: null,
                    render: function (data, type, row, meta) {
                        return meta.row + 1;
                    }
                },

                { data: 'ExpensesHead' },
                { data: 'PersonName' },
                { data: 'Amount' },
                { data: 'PayMode' },
                { data: 'Remark' },

                {
                    data: 'BillImg',
                    render: function (data) {
                        if (data)
                            return '<a href="/Uploads/' + data + '" target="_blank">View</a>';
                        else
                            return '';
                    }
                },

                {
                    data: 'BillDate',
                   
                   
                },

                {
                    data: 'ExpensesID',
                    render: function (data) {

                        return '<button class="btn btn-danger btn-sm" onclick="DeleteExpense(' + data + ')">Delete</button>';
                    }
                }
            ]
        });

    });


    function DeleteExpense(id) {

        if (!confirm("Are you sure you want to delete this record?"))
            return;

        $.ajax({
            url: '/Admin/DeleteExpenses',
            type: 'POST',
            data: { id: id },

            success: function (response) {

                if (response.result) {

                    alert(response.message);

                    table.ajax.reload(); // refresh datatable

                } else {

                    alert(response.message);
                }
            },

            error: function () {

                alert("Delete failed");
            }
        });
    }


    function Success(response) {

        if (response.Status) {

            alert(response.Message);

            $('#formsubmit')[0].reset();

            table.ajax.reload(); // refresh table
        }
    }


    function Fail() {

        alert("Error occurred");
    }

</script>
