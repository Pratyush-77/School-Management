

@model WebApplication7.Models.AddClassModel
@{
    ViewBag.Title = "AddClass";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="right_col" role="main">
    <div class="col-md-4 col-sm-4 col-xs-12">
        <div class="x_panel">
            <div class="x_title">
                <h2 style="font-size:16px;">➕ Add Class <small></small></h2>
                <div class="clearfix"></div>
            </div>
            <div class="x_content">

                @using (Ajax.BeginForm("AddClass", "Admin", new AjaxOptions() { OnSuccess = "Success", OnFailure = "Fail" }, new { @id = "formsubmit", @class = "form-horizontal" }))
                {
                    <div>
                        @Html.HiddenFor(m => m.ClassId)
                    </div>

                    <div class="form-group row">
                        <div class="col-md-12 col-sm-12 col-xs-12">
                            <label class="control-label">
                                Class Name <span class="star"></span>
                            </label>
                            @Html.TextBoxFor(
                                m => m.ClassName,
                                new
                                {
                                    @class = "form-control",
                                    @required = "required",
                                    @placeholder = "e.g. Nursery,K.G.1,Class 1 ..."
                                }
                            )
                            @Html.ValidationMessageFor(m => m.ClassName, "", new { @class = "label label-danger" })
                        </div>




                    </div>
                    <div class="form-group row">
                        <label class="col-md-2 col-sm-2 col-xs-12 control-label"></label>
                        <div class="col-md-10 col-sm-10 col-xs-12">
                            <input type="submit" id="btnsubmit" class="btn btn-success" value="Submit" />
                            <input type="submit" id="btnupdate" class="btn btn-success" value="Update" />
                            <input type="button" id="btncancel" onclick="Cancel();" class="btn btn-primary" value="Cancel" />
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Events List Table -->
    <div class="col-md-8 col-sm-8 col-xs-12">
        <div class="x_panel">
            <div class="x_content">
                <div class="row">
                    <div class="col-md-12 col-xs-12">
                        <div class="table-responsive">
                            <table id="tblClass" class="table table-bordered">
                                <thead>
                                    <tr class="bg-green">
                                        <th>Sl. No</th>
                                        <th>Class Name</th>
                                        <th>Status</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<script>

    $(document).ready(function () {
        AllClassLists();
        Cleartxt();
    });

    var DataTable = null;
    function AllClassLists() {
        DataTable = $("#tblClass").DataTable({

            "ajax": {
                "type": "GET",
                "url": "/Admin/GetAddClassList",
                "datatype": "JSON"
            },
            "columns": [
                {
                    "render": function (data, type, full, meta) {
                        return meta.row + 1;
                    }
                },
                { "data": "ClassName" },
                {
                    "data": function (val, type) {
                        if (val.Status == true) {
                            return "<a class = 'label label-success'onclick=StatusChange(" + val.ClassId + ") >Active </a>"
                        }
                        else {
                            return "<a class='label label-danger'onclick=StatusChange(" + val.ClassId + ")> DeActive </a>"
                        }
                    }
                },
                {
                    "data": "ClassId", "render": function (data) {
                        return "<a class= 'btn btn-primary btn-xs' onclick = editrow(" + data + ")><i class = 'glyphicon glyphicon-edit'></i></a> <a class = 'btn btn-danger btn-xs' onclick= deleterow(" + data + ")><i class='glyphicon glyphicon-trash'></i></a>";
                    },
                    orderable: false
                },
            ],
            "language": {
                "emptyTable": "Data Not Found. Click on Add New Button"
            },
        });
    }

    function Cleartxt() {
        $("#ClassId").val('');
        $("#ClassName").val('');
        $("#btnsubmit").show();
        $("#btnupdate").hide();
        $("#btncancel").hide();
    }

    function Cancel() {
        Cleartxt();
        $("#btnsubmit").show();
        $("#btnupdate").hide();
        $("#btncancle").hide();
    }

    function Success(response) {
        if (response.result == true) {
            Cleartxt();
            $.notify(response.message, { globalPosition: 'top right', className: 'success' });
            DataTable.ajax.reload();
        }
        else {
            $.notify(response.message, { globalPosition: 'top right', className: 'error' });
            DataTable.ajax.reload
        }
    }


    function editrow(id) {
        $.ajax({
            type: "POST",
            url: '/Admin/EditClass/' + id,
            success: function (res) {
                $("#ClassId").val(id);
                $("#ClassName").val(res.ClassName);
                $("#btnsubmit").hide();
                $("#btnupdate").show();
                $("#btncancel").show();
            },
            error: function (msg) {
                alert(msg.responseText);
            }
        })
    };


    function deleterow(id) {
        if (confirm('Are You sure you want to delete this record...?')) {
            $.ajax({
                type: "POST",
                url: '/Admin/DeleteClass/' + id,
                success: function (response) {
                    if (response.result == true) {
                        $.notify(response.message, { globalPosition: 'top right', className: 'success' });
                        DataTable.ajax.reload();
                    }
                    else {
                        $.notify(response.message, { globalPosition: 'top right', className: 'error' });
                        DataTable.ajax.reload();
                    }
                },
                error: function (msg) {
                    alert(msg.responseText);
                }
            })
        }
    }


    function StatusChange(id) {
        if (confirm('Are You Sure want to change Status?')) {
            $.ajax({
                type: "POST",
                url: "/Admin/ClassStatus/" + id,
                success: function (response) {
                    if (response.result) {
                        $.notify(response.message, { globalPosition: 'top right', className: 'success' });
                        DataTable.ajax.reload();
                    }
                },
                error: function (msg) {
                    $.notify(msg.responseText, { globalPosition: 'top right', className: 'error' })
                }
            })
        }
    };


</script>




