@model WebApplication7.Models.AdmissionListModel
@{
    ViewBag.Title = "AdmissionList";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="right_col" role="main">
    <div class="col-md-12 col-sm-12 col-xs-12">
        <div class="x_panel">
            <div class="x_title">
                <h2 style="font-size:16px;">➕Admission List  <small></small></h2>
                <div class="clearfix"></div>
            </div>
            <div class="x_content">


                <div class="container mt-4">


                    <!-- Form Section -->
                    <div class="form-box">

                        <form>

                            <div class="form-row">
                                
                                <!-- Admission No -->
                                <div class="form-group col-md-3">
                                    <label>Admission No<span class="required">*</span></label>
                                    <input type="text" id="AdmissionNo" class="form-control">
                                </div>

                                <!-- Class Wise -->
                                <div class="form-group col-md-3">
                                    <label>Class Wise <span class="required">*</span></label>
                                    @Html.DropDownListFor(m => m.ClassID, Model.ClassList, "-- Select Class --", new { @class = "form-control", id = "ClassID" })
                                    @Html.ValidationMessageFor(m => m.ClassID, "", new { @class = "label label-danger" })
                                </div>

                                <!-- Section Wise -->
                                <div class="form-group col-md-3">
                                    <label>Section Wise<span class="required">*</span></label>
                                    @Html.DropDownListFor(m => m.SectionID, Model.SectionList, "-- Select Section --", new { @class = "form-control", id = "SectionID" })
                                    @Html.ValidationMessageFor(m => m.SectionID, "", new { @class = "label label-danger" })
                                </div>

                                <!-- Session Wise -->
                                <div class="form-group col-md-3">
                                    <label>Session Wise<span class="required">*</span></label>
                                    @Html.DropDownListFor(m => m.SessionID, Model.SessionList, "-- Select Session --", new { @class = "form-control", id = "SessionID" })
                                    @Html.ValidationMessageFor(m => m.SessionID, "", new { @class = "label label-danger" })
                                </div>

                            </div>

                        </form>

                    </div>

                    <!-- Buttons -->
                    <div class="mt-3">

                        <button id="btnSearch" type="button" class="btn btn-success">
                            🔎 Search
                        </button>

                        <button id="btnClear" class="btn btn-warning">
                            ♻ Clear
                        </button>

                    </div>

                </div>
            </div>
        </div>
    </div>

    <br />
    <br />
    <div class="container mt-4">

        <table id="studentTable" class="display table table-bordered">

            <thead style="background:#2f6070;color:white;">
                <tr>
                    <th>Sr. No.</th>
                    <th>Admission No.</th>
                    <th>Student Name</th>
                    <th>Father Name</th>
                    <th>Father Mobile</th>
                    <th>Class</th>
                    <th>Section</th>
                    <th>Session</th>
                    <th>Fee</th>
                    <th>Addmission Date</th>
                    <th>Action</th>
                </tr>
            </thead>
        </table>
    </div>
</div>

<script>

var table;

$(document).ready(function () {

    table = $('#studentTable').DataTable({

        dom: 'lBfrtip',
        buttons: ['excel','csv','print'],

        processing: true,
        searching: false,
        paging: true,
        info: true,

        columns: [
            { data: null },
            { data: "AdmissionNo" },
            { data: "StudentName" },
            { data: "FatherName" },
            { data: "FatherMobileNo" },
            { data: "ClassName" },
            { data: "SectionName" },
            { data: "SessionName" },
            { data: "Fee" },
            { data: "AdmissionDate" },
            {
                data: "AdmissionID",
                render: function (data) {
                    return `
            <button class="btn btn-primary btn-sm" onclick="PromoteStudent(${data})">
                Promote
            </button>
            <button class="btn btn-danger btn-sm" onclick="DeleteAdmissionList(${data})">
                Delete
            </button>
        `;
      
                }
            }
        ],

        columnDefs: [{
            targets: 0,
            render: function (data, type, row, meta) {
                return meta.row + 1;
            }
        }]
    });

    // AUTO LOAD
    loadAdmissionData();

    $("#btnSearch").click(function () {
        loadAdmissionData();
    });

    $("#btnClear").click(function () {

        $("#AdmissionNo").val('');
        $("#ClassID").val('');
        $("#SectionID").val('');
        $("#SessionID").val('');

        loadAdmissionData();
    });

    function loadAdmissionData() {

        $.ajax({
            url: '@Url.Action("GetAdmissionList","Admin")',
            type: "POST",
            data: {
                admissionNo: $("#AdmissionNo").val(),
                classId: $("#ClassID").val(),
                sectionId: $("#SectionID").val(),
                sessionId: $("#SessionID").val()
            },
            success: function (response) {

                table.clear();
                table.rows.add(response.data); // FIX
                table.draw();
            },
            error: function () {
                alert("Error loading data");
            }
        });
    }

});

    function PromoteStudent(id) {

        // Redirect to Promote Page with AdmissionID
        window.location.href = '/Admin/PromoteStudent?id=' + id;

    }  


    function DeleteAdmissionList(id) {

        if (!confirm("Are you sure you want to delete this record?"))
            return;

        $.ajax({
            url: '/Admin/DeleteAdmissionList',
            type: 'POST',
            data: { id: id },

            success: function (response) {

                if (response.result) {

                    alert(response.message);

                    table.ajax.reload(); // refresh datatable

                } else {

                    alert(response.message);
                }
            },

            error: function () {

                alert("Delete failed");
            }
        });
    }

   
</script>
