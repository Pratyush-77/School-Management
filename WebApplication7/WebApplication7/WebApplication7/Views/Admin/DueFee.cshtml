@model WebApplication7.Models.DueFeeModel
@{
    ViewBag.Title = "DueFee";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<div class="right_col" role="main">

    <div class="col-md-12 col-sm-12 col-xs-12">
        <div class="x_panel">

            <div class="x_title">
                <h2 style="font-size:16px;">➕ Due Fee</h2>
                <div class="clearfix"></div>
            </div>

            <div class="x_content">

                <!-- Row 1 -->
                <div class="row">

                    <!-- Admission No -->
                    <div class="col-md-3 col-sm-6 col-xs-12">
                        <label>Admission No</label>
                        <input type="text" class="form-control" placeholder="Enter Admission No">
                    </div>

                    <!-- Class -->
                    <div class="col-md-3 col-sm-6 col-xs-12">
                        <label>Class</label>
                        @Html.DropDownListFor(m => m.ClassID, Model.ClassList, "-- Select Class --", new { @class = "form-control", id = "ClassID" })
                        @Html.ValidationMessageFor(m => m.ClassID, "", new { @class = "label label-danger" })
                    </div>

                    <!-- Section -->
                    <div class="col-md-3 col-sm-6 col-xs-12">
                        <label>Section</label>
                        @Html.DropDownListFor(m => m.SectionID, Model.SectionList, "-- Select Section --", new { @class = "form-control", id = "SectionID" })
                        @Html.ValidationMessageFor(m => m.SectionID, "", new { @class = "label label-danger" })
                    </div>

                    <!-- Session -->
                    <div class="col-md-3 col-sm-6 col-xs-12">
                        <label>Session</label>
                        @Html.DropDownListFor(m => m.SessionID, Model.SessionList, "-- Select Session --", new { @class = "form-control", id = "SessionID" })
                        @Html.ValidationMessageFor(m => m.SessionID, "", new { @class = "label label-danger" })
                    </div>

                </div>

                <br>

                <!-- Row 2 -->
                <div class="row">

                    <!-- From Date -->
                    <div class="col-md-3 col-sm-6 col-xs-12">
                        <label>From Date</label>
                        <input type="date" class="form-control">
                    </div>

                    <!-- To Date -->
                    <div class="col-md-3 col-sm-6 col-xs-12">
                        <label>To Date</label>
                        <input type="date" class="form-control">
                    </div>

                    <!-- Button -->
                    <div class="col-md-3 col-sm-6 col-xs-12" style="margin-top:25px;">
                        <button type="submit" class="btn btn-success">
                            Search
                        </button>
                    </div>

                </div>
                <div class="container" style="margin-top:30px;">

                    <table id="studentTable" class="table table-striped table-bordered">

                        <thead>
                            <tr>
                                <th>Sr. No.</th>
                                <th>Admission No.</th>
                                <th>Student Name</th>
                                <th>Class</th>
                                <th>Total Amt</th>
                                <th>Paid Amt</th>
                                <th>Balance Amt</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                    </table>
                </div>


            </div>

        </div>
    </div>

</div>

<script>
    $(document).ready(function () {

        $('#studentTable').DataTable({
            dom: 'lBfrtip',
            buttons: [
                {
                    extend: 'excel',
                    text: 'Excel',
                    className: 'btn btn-success'
                },
                {
                    extend: 'csv',
                    text: 'CSV',
                    className: 'btn btn-info'
                },
                {
                    extend: 'print',
                    text: 'Print',
                    className: 'btn btn-warning'
                }
            ]
        });

    });
</script>


